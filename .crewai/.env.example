# ============================================================================
# CrewAI Environment Variables
# ============================================================================
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to the repository — only .env.example.
#
# For GitHub Actions, add these as repository secrets:
#   Settings → Secrets and variables → Actions → New repository secret
# See SECRETS.md in the repo root for detailed setup instructions.
# ============================================================================

# NVIDIA API Key (PREFERRED)
# Get yours at: https://build.nvidia.com/moonshotai/kimi-k2.5
# When set, CrewAI uses NVIDIA NIM with moonshotai/kimi-k2-5 for all crews.
NVIDIA_API_KEY=nvapi-your-nvidia-api-key-here

# OpenRouter API Key (FALLBACK)
# Used only when NVIDIA_API_KEY is not set.
# Get yours at: https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key-here

# GitHub Token (required for LOCAL testing only — auto-provided in Actions)
# Get from: https://github.com/settings/tokens
# Scopes needed: repo (private repos) or public_repo (public repos)
GITHUB_TOKEN=ghp_your-github-token-here

# GitHub Context (auto-set by Actions — only needed for local testing)
GITHUB_REPOSITORY=your-org/your-repo
PR_NUMBER=1
COMMIT_SHA=abc1234

# ============================================================================
# Optional: Model Configuration
# ============================================================================
# Override the default model (see utils/model_config.py for full registry)
# MODEL_KEY=gemini-3-flash          # Ignored when NVIDIA_API_KEY is present
# See available models: https://openrouter.ai/models

# ============================================================================
# Optional: mem0 Memory (persistent review memory across CI runs)
# ============================================================================
# To use mem0 Cloud instead of local JSON memory:
# MEM0_API_KEY=m0-your-mem0-api-key-here
# USE_MEM0_CLOUD=true
#
# Get your key at: https://app.mem0.ai/
# Free tier: 1000 memories, perfect for most projects

# ============================================================================
# Optional: CrewAI Tuning
# ============================================================================
# CREWAI_TELEMETRY_OPT_OUT=true    # Disable CrewAI telemetry
# CREWAI_LOG_LEVEL=INFO             # DEBUG, INFO, WARNING, ERROR

# ============================================================================
# Optional: Project Identity (used in OpenRouter HTTP headers for tracking)
# ============================================================================
# GITHUB_REPOSITORY_URL=https://github.com/your-org/your-repo
# PROJECT_TITLE=My Project CrewAI Review
