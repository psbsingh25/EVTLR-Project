# =============================================================================
# Root Environment Variables
# =============================================================================
# Copy this to .env and fill in your values.
# See SECRETS.md for GitHub Actions secret setup.
# NEVER commit .env files — they are in .gitignore.
# =============================================================================

# --- NVIDIA (AI Code Review, Preferred) ---
# Preferred provider for CrewAI code review.
# Uses moonshotai/kimi-k2-5 via NVIDIA NIM when present.
# Get a key at https://build.nvidia.com/moonshotai/kimi-k2.5
NVIDIA_API_KEY=

# --- OpenRouter (AI Code Review, Fallback) ---
# Used only when NVIDIA_API_KEY is not set.
# Get a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# --- Cloudflare (Website Deployment) ---
# Required only for deploy steps. CI skips deploy if not set.
# https://dash.cloudflare.com/profile/api-tokens
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# --- Google OAuth (Authentication) ---
# Required for login/protected sections. Get credentials at:
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8788/auth/callback

# --- Authorized Users ---
# Comma-separated list of email addresses allowed to access protected content.
# Only Google accounts with these emails can log in.
ALLOWED_EMAILS=

# --- GitHub ---
# Automatically set in GitHub Actions. For local use, create a PAT:
# https://github.com/settings/tokens
GITHUB_TOKEN=

# --- mem0 (Optional: Persistent AI Review Memory) ---
# Enables cloud-based review memory across CI runs.
# Default: JSON-in-repo memory (no setup needed).
# To upgrade: https://app.mem0.ai
# USE_MEM0_CLOUD=true
# MEM0_API_KEY=

# --- Project Identity (used in HTTP headers for API calls) ---
# PROJECT_NAME=my-project
# PROJECT_URL=https://github.com/owner/my-project
